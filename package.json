{
  "name": "haevn-extension",
  "version": "1.1.0",
  "description": "A Chrome extension with TypeScript and Tailwind",
  "type": "module",
  "scripts": {
    "build:content": "esbuild src/content/content.ts --bundle --format=iife --outfile=dist/content.js --sourcemap",
    "build:popup": "esbuild src/popup/popup.ts   --bundle --format=iife --outfile=dist/popup.js --sourcemap",
    "build:options": "esbuild src/options/options.tsx --bundle --format=iife --outfile=dist/options.js --jsx=automatic --inject:./src/lib/react-shim.js --sourcemap",
    "build:bg": "esbuild src/background/background.ts --bundle --format=iife --outfile=dist/background.js --sourcemap",
    "build:viewer": "esbuild src/viewer/viewer.tsx --bundle --format=iife --outfile=dist/viewer.js --jsx=automatic --inject:./src/lib/react-shim.js --sourcemap",
    "build:logs-viewer": "esbuild src/logs/logs-viewer.ts --bundle --format=iife --outfile=dist/logs-viewer.js --sourcemap",
    "build:import-worker": "esbuild src/background/import/import.worker.ts --bundle --format=iife --outfile=dist/import.worker.js --sourcemap",
    "build:search-worker": "esbuild src/services/search.worker.ts --bundle --format=iife --outfile=dist/search.worker.js --sourcemap",
    "build:stats-worker": "esbuild src/services/stats.worker.ts --bundle --format=iife --outfile=dist/stats.worker.js --sourcemap",
    "build:thumbnail-worker": "esbuild src/services/thumbnail.worker.ts --bundle --format=iife --outfile=dist/thumbnail.worker.js --sourcemap",
    "build:bulkExport-worker": "esbuild src/background/bulkExport/bulkExport.worker.ts --bundle --format=iife --outfile=dist/bulkExport.worker.js --sourcemap",
    "build:bulkSync-worker": "esbuild src/background/bulkSync/bulkSync.worker.ts --bundle --format=iife --outfile=dist/bulkSync.worker.js --sourcemap",
    "build:offscreen": "esbuild src/offscreen/offscreen.ts --bundle --format=iife --outfile=dist/offscreen.js --sourcemap",
    "build:css": "tailwindcss -i src/popup/popup.css -o dist/popup.css --minify",
    "build:viewer:css": "tailwindcss -i src/viewer/viewer.css -o dist/viewer.css --minify",
    "build:logs-viewer:css": "echo 'logs-viewer.css copied by copy-static.js'",
    "build:copy": "node scripts/copy-static.js",
    "build": "rm -rf dist && run-s build:content build:popup build:options build:bg build:viewer build:logs-viewer build:import-worker build:search-worker build:stats-worker build:thumbnail-worker build:bulkExport-worker build:bulkSync-worker build:offscreen build:css build:viewer:css build:logs-viewer:css build:copy",
    "lint": "biome check ./src",
    "lint:fix": "biome check --write ./src",
    "format": "biome format --write ./src",
    "test": "vitest",
    "hook:pre-commit": "bash scripts/hooks/pre-commit.sh",
    "hook:pre-push": "bash scripts/hooks/pre-push.sh",
    "prepare": "simple-git-hooks",
    "version:patch": "./scripts/version-bump.sh patch",
    "version:minor": "./scripts/version-bump.sh minor",
    "version:major": "./scripts/version-bump.sh major",
    "release:patch": "./scripts/quick-release.sh patch",
    "release:minor": "./scripts/quick-release.sh minor",
    "release:major": "./scripts/quick-release.sh major",
    "cli:version:patch": "./scripts/cli-version-bump.sh patch",
    "cli:version:minor": "./scripts/cli-version-bump.sh minor",
    "cli:version:major": "./scripts/cli-version-bump.sh major",
    "cli:release:patch": "./scripts/cli-quick-release.sh patch",
    "cli:release:minor": "./scripts/cli-quick-release.sh minor",
    "cli:release:major": "./scripts/cli-quick-release.sh major",
    "release:all": "./scripts/release-all.sh",
    "package": "cd dist && zip -r ../haevn-extension-v$(node -p \"require('../package.json').version\").zip . && cd .. && echo 'Package created: haevn-extension-v'$(node -p \"require('./package.json').version\")'.zip'"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.7",
    "@eslint/js": "^9.39.2",
    "@types/chrome": "^0.1.33",
    "@types/dompurify": "^3.2.0",
    "@types/firefox-webext-browser": "^143.0.0",
    "@types/lunr": "^2.3.7",
    "@types/marked": "^5.0.2",
    "@types/node": "^20.19.28",
    "@types/object-hash": "^3.0.6",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@types/react-window": "^1.8.8",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.23",
    "chrome-types": "^0.1.410",
    "esbuild": "^0.25.12",
    "eslint": "^9.39.2",
    "fake-indexeddb": "^6.2.5",
    "npm-run-all-next": "^1.2.5",
    "object-hash": "^3.0.0",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.52.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@joplin/turndown-plugin-gfm": "^1.0.64",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@sinclair/typebox": "^0.34.48",
    "@zip.js/zip.js": "^2.8.15",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dexie": "^4.2.1",
    "dompurify": "^3.3.1",
    "jszip": "^3.10.1",
    "lunr": "^2.3.9",
    "marked": "^17.0.1",
    "parse-entities": "^4.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-window": "^1.8.11",
    "structalign": "^0.1.2",
    "tailwind-merge": "^2.6.0",
    "turndown": "^7.2.2",
    "uuid": "^11.1.0",
    "yaml": "^2.8.2",
    "zustand": "^4.5.7"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm run hook:pre-commit",
    "pre-push": "pnpm run hook:pre-push"
  },
  "vitest": {
    "setupFiles": [
      "tests/setup.ts"
    ]
  }
}
