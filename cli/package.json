{
  "name": "@haevn/cli",
  "version": "1.2.0",
  "description": "CLI tool for searching and accessing HAEVN chat archives",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aiamblichus/haevn.git",
    "directory": "cli"
  },
  "homepage": "https://github.com/aiamblichus/haevn#readme",
  "bugs": {
    "url": "https://github.com/aiamblichus/haevn/issues"
  },
  "keywords": [
    "haevn",
    "cli",
    "ai",
    "archive",
    "chat",
    "search"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "haevn": "./dist/index.mjs"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "unbuild",
    "dev": "unbuild --stub",
    "start": "node ./dist/index.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "biome check ./src",
    "lint:fix": "biome check --write ./src",
    "prepublishOnly": "pnpm run build && pnpm run typecheck"
  },
  "dependencies": {
    "citty": "^0.1.6",
    "consola": "^3.4.2",
    "pathe": "^2.0.3",
    "picocolors": "^1.1.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.7",
    "@types/node": "^22.15.21",
    "@types/ws": "^8.5.14",
    "typescript": "^5.9.3",
    "unbuild": "^3.5.0"
  }
}
